  "description": "飞书 ↔ Claude Code 网关 — Lark Bot 一键接入 Claude Code",
  "type": "module",
  "engines": {
    "node": ">=20.11"
  },
  "bin": {
    "chat-cc": "dist/cli/index.js",
    "chatcc": "dist/cli/index.js"
  },
  "files": [
